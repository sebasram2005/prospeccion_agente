# ─── LLM (Google Gemini) ───────────────────────────────────────
# Obtener en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...

# ─── Base de datos (Supabase) ──────────────────────────────────
# Obtener en: Supabase Dashboard → Settings → API
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Telegram Bot ──────────────────────────────────────────────
# Crear bot con @BotFather, obtener chat_id con @userinfobot
TELEGRAM_BOT_TOKEN=123456789:AABBccDDeeFFggHH...
TELEGRAM_CHAT_ID=123456789

# ─── HITL Gateway (Cloud Run URL) ──────────────────────────────
HITL_GATEWAY_URL=https://hitl-gateway-xxxxxxx-uc.a.run.app

# ─── Email (Brevo SMTP) ────────────────────────────────────────
# Obtener en: Brevo → SMTP & API → SMTP tab
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=tu-email@gmail.com
BREVO_SMTP_PASSWORD=xsmtpsib-xxxxxxxxxxxx...

# ─── Senders ───────────────────────────────────────────────────
SENDER_V1_NAME=Tu Nombre
SENDER_V1_EMAIL=tu@dominio.com
SENDER_V2_NAME=Tu Nombre | Tu Marca
SENDER_V2_EMAIL=hello@tumarca.com

# ─── Scraping Config ───────────────────────────────────────────
GOOGLE_PLACES_API_KEY=AIza...
TARGET_CITIES=New York,Miami,Los Angeles,London,Paris,Barcelona
MAX_LEADS_PER_RUN=30
MIN_BUDGET_USD=500

# ─── Dev / Debug ───────────────────────────────────────────────
INSTAGRAM_MOCK=false
LOG_LEVEL=INFO
